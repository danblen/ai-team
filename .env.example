# ---- LLM 配置 (OpenAI 兼容接口) ----
# 你的 API Key（必填，用于真实生成）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# API Base URL，兼容 OpenAI Chat Completions 协议
# OpenAI 官方: https://api.openai.com/v1
# 也可填入任意兼容服务，例如 DeepSeek / 通义 / 本地 vLLM 等
OPENAI_BASE_URL=https://api.openai.com/v1

# 使用的模型名
OPENAI_MODEL=gpt-4o-mini

# 后端服务端口（可选，默认 5025）
SERVER_PORT=5025

# ---- Remote 访问配置（可选） ----
# 设置后所有 /api/* 请求需携带 Authorization: Bearer <token>
# 部署到公网时务必设置
# API_TOKEN=my-secret-token

# ---- 登录鉴权（邮箱+密码） ----
# 会话令牌的签名密钥。不填则自动生成并存于 server/.data/secret
# 部署到公网建议显式设置一个高强度随机串
# AUTH_SECRET=change-me-to-a-long-random-string

# 是否强制登录。默认：一旦有用户注册（server/.data/users.json）或设置了 API_TOKEN 即强制。
# 想在没有任何用户时也强制登录，设为 1
# AUTH_REQUIRED=1

# CORS 允许的来源，逗号分隔（可选，默认允许所有来源）
# 生产环境建议设为你的前端域名
# ALLOWED_ORIGINS=https://ai-team.example.com
